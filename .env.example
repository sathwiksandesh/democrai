# ── DemocrAI Environment Variables ──────────────────────────
# Copy this file to .env and fill in your actual API keys.
# SECURITY: All keys loaded from env vars — never hardcoded.

# Google Gemini AI (Required — powers the AI assistant)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Firebase (Required — election timeline data)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_APP_ID=your_app_id_here

# Google Cloud Translation API v2 (Optional — multi-language support)
VITE_GOOGLE_TRANSLATE_API_KEY=your_translate_api_key_here

# Google Maps Platform (Optional — polling booth locator)
VITE_GOOGLE_MAPS_API_KEY=your_maps_api_key_here

# Google Vertex AI (Optional — semantic FAQ search)
VITE_VERTEX_API_KEY=your_vertex_api_key_here

# Google Cloud Natural Language API (Optional — query analytics)
VITE_GOOGLE_NLP_API_KEY=your_nlp_api_key_here

# Google Analytics 4 (Optional — replace G-XXXXXXXXXX in index.html)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
