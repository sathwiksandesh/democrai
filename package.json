{
  "name": "democrai",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered civic education platform guiding Indian voters through every step of the election process. Built with React, Vite, and 7 integrated Google Cloud services.",
  "type": "module",
  "keywords": [
    "election", "india", "voter-education", "civic-tech",
    "gemini", "firebase", "google-cloud-translation", "google-maps",
    "google-calendar", "vertex-ai", "google-cloud-natural-language",
    "accessibility", "wcag", "react", "vite"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .js,.jsx",
    "format": "prettier --write \"src/**/*.{js,jsx,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,html}\"",
    "validate": "npm run lint && npm run test:coverage"
  },
  "dependencies": {
    "firebase": "^10.14.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.35",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  }
}
